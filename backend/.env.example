NODE_ENV=development
PORT=3000

# PostgreSQL (Supabase)
DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:5432/<db_name>?schema=public

# JWT
JWT_ACCESS_SECRET=<replace_with_access_secret>
JWT_REFRESH_SECRET=<replace_with_refresh_secret>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Crypto
AES_KEY=<32_characters_exactly_for_aes_256>

# Bling environment selector: homolog | production
BLING_ENV=homolog
BLING_BASE_URL_HOMOLOG=https://www.bling.com.br/Api/v3
BLING_BASE_URL_PRODUCTION=https://www.bling.com.br/Api/v3
BLING_API_KEY_HOMOLOG=<replace_with_homolog_key>
BLING_API_KEY_PRODUCTION=<replace_with_production_key>
BLING_TIMEOUT_MS=12000
BLING_RETRY_MAX=3
BLING_RETRY_BASE_MS=500
BLING_RATE_LIMIT_RPS=4

# S3-compatible (optional for signature upload)
S3_ENDPOINT=<https://s3.provider.com>
S3_REGION=<sa-east-1>
S3_ACCESS_KEY_ID=<replace>
S3_SECRET_ACCESS_KEY=<replace>
S3_BUCKET=<replace>
