NODE_ENV=homolog
PORT=3000

# Supabase PostgreSQL (homologação)
DATABASE_URL="postgresql://postgres:Tyq377wlWPQcrOOO@db.shdqahizdvrieoyagkdr.supabase.co:5432/postgres"

# JWT
JWT_ACCESS_SECRET="<replace_access_secret>"
JWT_REFRESH_SECRET="<replace_refresh_secret>"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Crypto
AES_KEY="<32_characters_exactly_for_aes_256>"

# Bling
BLING_ENV="homolog"
BLING_BASE_URL_HOMOLOG="https://www.bling.com.br/Api/v3"
BLING_BASE_URL_PRODUCTION="https://www.bling.com.br/Api/v3"
BLING_API_KEY_HOMOLOG="<replace_homolog_key>"
BLING_API_KEY_PRODUCTION="<replace_production_key>"
BLING_TIMEOUT_MS="12000"
BLING_RETRY_MAX="3"
BLING_RETRY_BASE_MS="500"
BLING_RATE_LIMIT_RPS="4"

# S3-compatible
S3_ENDPOINT="<https://s3.provider.com>"
S3_REGION="sa-east-1"
S3_ACCESS_KEY_ID="<replace>"
S3_SECRET_ACCESS_KEY="<replace>"
S3_BUCKET="<replace>"